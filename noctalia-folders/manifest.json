{
  "id": "noctalia-folders",
  "name": "Noctalia Folders",
  "version": "3.1.0",
  "minNoctaliaVersion": "3.6.0",
  "author": "Christopher",
  "license": "MIT",
  "repository": "https://github.com/runinit/noctalia-folders",
  "description": "Recolors folder icons to match your Noctalia accent color. Supports Papirus and Adwaita with recolor or closest-match modes, optional dim mode, and GTK/QT icon theme integration.",
  "tags": ["Utility", "Theming"],
  "entryPoints": {
    "main": "Main.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "enabled": false,
      "autoApply": true,
      "iconTheme": "papirus-recolor",
      "dimMode": false,
      "accentSource": "mPrimary",
      "debugMode": false,
      "setGtkTheme": true,
      "setQtTheme": true
    }
  }
}
